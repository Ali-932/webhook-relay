{
  "name": "webhook-relay-cli",
  "version": "1.0.0",
  "description": "Receive webhooks on a Cloudflare Worker and relay them to your local app — listen, replay, and a live TUI.",
  "type": "module",
  "bin": {
    "relay": "dist/index.js"
  },
  "files": [
    "dist",
    "!dist/**/*.test.js"
  ],
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "webhook",
    "relay",
    "cli",
    "tui",
    "cloudflare",
    "localhost",
    "tunnel"
  ],
  "license": "MIT",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "node --watch dist/index.js",
    "prepublishOnly": "rm -rf dist && tsc"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.17",
    "typescript": "^5.2.0"
  },
  "dependencies": {
    "ink": "^7.1.0",
    "react": "^19.2.7"
  }
}