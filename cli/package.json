{
  "name": "webhook-relay-cli",
  "version": "1.0.0",
  "description": "Receive webhooks on a Cloudflare Worker and relay them to your local app — listen, replay, and a live TUI.",
  "type": "module",
  "bin": {
    "relay": "dist/index.js"
  },
  "files": [
    "dist",
    "!dist/**/*.test.js",
    "worker-template"
  ],
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "webhook",
    "relay",
    "cli",
    "tui",
    "cloudflare",
    "localhost",
    "tunnel"
  ],
  "license": "MIT",
  "author": "Ali-932",
  "homepage": "https://github.com/Ali-932/webhook-relay#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ali-932/webhook-relay.git",
    "directory": "cli"
  },
  "bugs": {
    "url": "https://github.com/Ali-932/webhook-relay/issues"
  },
  "scripts": {
    "build": "node scripts/copy-worker.mjs && tsc",
    "start": "node dist/index.js",
    "dev": "node --watch dist/index.js",
    "prepublishOnly": "rm -rf dist worker-template && npm run build && cp ../README.md README.md && sed -i 's|](.github/assets/|](https://raw.githubusercontent.com/Ali-932/webhook-relay/main/.github/assets/|g' README.md"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.17",
    "typescript": "^5.2.0"
  },
  "dependencies": {
    "ink": "^7.1.0",
    "react": "^19.2.7"
  }
}